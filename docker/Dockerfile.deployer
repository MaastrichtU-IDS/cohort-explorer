FROM node:20-alpine

WORKDIR /app

RUN apk add --no-cache curl jq

COPY package.json package-lock.json* ./
RUN npm install

COPY tsconfig.json hardhat.config.ts ./
COPY contracts/ ./contracts/
COPY scripts/ ./scripts/
COPY api/services/ontology/icd10_hierarchy.json ./api/services/ontology/icd10_hierarchy.json

RUN npx hardhat compile

COPY deploy-and-generate.sh ./
RUN chmod +x deploy-and-generate.sh

CMD ["./deploy-and-generate.sh"]
